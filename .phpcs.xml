<?xml version="1.0"?>
<ruleset name="WP Career Board">
    <description>WP Career Board Coding Standards — WordPress + wcb_ prefix enforcement</description>

    <arg name="extensions" value="php"/>
    <arg name="colors"/>
    <arg value="sp"/>

    <!-- WordPress Coding Standards -->
    <rule ref="WordPress"/>
    <rule ref="WordPress-Docs"/>
    <rule ref="WordPress-Extra"/>

    <!-- Enforce wcb_ prefix on all globals -->
    <rule ref="WordPress.NamingConventions.PrefixAllGlobals">
        <properties>
            <property name="prefixes" type="array">
                <element value="wcb_"/>
                <element value="WCB"/>
            </property>
        </properties>
        <!-- WCB is 3 chars — WPCS flags it as "too short" but it is our chosen namespace -->
        <exclude name="WordPress.NamingConventions.PrefixAllGlobals.ShortPrefixPassed"/>
    </rule>

    <!-- Custom autoloader uses PascalCase-to-hyphenated filenames (e.g. JobsModule → class-jobs-module.php).
         WPCS cannot derive hyphens from compound PascalCase names (JobsEndpoint → class-jobsendpoint.php vs
         class-jobs-endpoint.php), so we disable the strict class-file-name check entirely. -->
    <rule ref="WordPress.Files.FileName">
        <properties>
            <property name="strict_class_file_names" value="false"/>
        </properties>
        <exclude name="WordPress.Files.FileName.InvalidClassFileName"/>
    </rule>

    <!-- Minimum WP version for deprecated checks -->
    <config name="minimum_supported_wp_version" value="6.9"/>

    <!-- PHP version -->
    <config name="testVersion" value="8.1-"/>

    <!-- Declare WCB custom capabilities so WordPress.WP.Capabilities.Unknown does not fire -->
    <rule ref="WordPress.WP.Capabilities">
        <properties>
            <property name="custom_capabilities" type="array">
                <element value="wcb_post_jobs"/>
                <element value="wcb_manage_company"/>
                <element value="wcb_view_applications"/>
                <element value="wcb_apply_jobs"/>
                <element value="wcb_manage_resume"/>
                <element value="wcb_bookmark_jobs"/>
                <element value="wcb_moderate_jobs"/>
                <element value="wcb_manage_settings"/>
                <element value="wcb_view_analytics"/>
                <element value="wcb_access_employer_dashboard"/>
            </property>
        </properties>
    </rule>

    <!-- Exclude generated/vendor directories -->
    <exclude-pattern>*/vendor/*</exclude-pattern>
    <exclude-pattern>*/node_modules/*</exclude-pattern>
    <exclude-pattern>*/build/*</exclude-pattern>
    <exclude-pattern>*/assets/js/build/*</exclude-pattern>
</ruleset>

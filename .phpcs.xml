<?xml version="1.0"?>
<ruleset name="WP Career Board">
    <description>WP Career Board Coding Standards — WordPress + wcb_ prefix enforcement</description>

    <arg name="extensions" value="php"/>
    <arg name="colors"/>
    <arg value="sp"/>

    <!-- WordPress Coding Standards -->
    <rule ref="WordPress"/>
    <rule ref="WordPress-Docs"/>
    <rule ref="WordPress-Extra"/>

    <!-- Enforce wcb_ prefix on all globals -->
    <rule ref="WordPress.NamingConventions.PrefixAllGlobals">
        <properties>
            <property name="prefixes" type="array" value="wcb_,WCB"/>
        </properties>
    </rule>

    <!-- Minimum WP version for deprecated checks -->
    <config name="minimum_supported_wp_version" value="6.9"/>

    <!-- PHP version -->
    <config name="testVersion" value="8.1-"/>

    <!-- Exclude generated/vendor directories -->
    <exclude-pattern>*/vendor/*</exclude-pattern>
    <exclude-pattern>*/node_modules/*</exclude-pattern>
    <exclude-pattern>*/build/*</exclude-pattern>
    <exclude-pattern>*/assets/js/build/*</exclude-pattern>
</ruleset>

{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "wp-career-board/company-archive",
  "version": "0.1.0",
  "title": "Company Archive",
  "category": "widgets",
  "description": "Interactive company directory with grid/list toggle and industry/size filters.",
  "editorScript": "file:./index.js",
  "textdomain": "wp-career-board",
  "attributes": {
    "perPage": {
      "type": "integer",
      "default": 20
    },
    "layout": {
      "type": "string",
      "default": "grid",
      "enum": [
        "grid",
        "list"
      ]
    }
  },
  "viewScriptModule": "file:./view.js",
  "style": "file:./style.css",
  "render": "file:./render.php",
  "supports": {
    "interactivity": true,
    "align": [ "wide", "full" ],
    "spacing": {
      "padding": true,
      "margin": true,
      "__experimentalDefaultControls": {
        "padding": false
      }
    }
  }
}

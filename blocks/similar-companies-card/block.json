{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "wp-career-board/similar-companies-card",
  "version": "1.0.0",
  "title": "Similar Companies",
  "category": "widgets",
  "description": "Sidebar card listing companies in the same industry. Auto-resolves on company-single pages or set Company ID manually.",
  "keywords": [ "career board", "wcb", "companies", "similar", "sidebar" ],
  "editorScript": "file:./index.js",
  "textdomain": "wp-career-board",
  "attributes": {
    "title":     { "type": "string",  "default": "" },
    "count":     { "type": "integer", "default": 5  },
    "companyId": { "type": "integer", "default": 0  }
  },
  "style": "file:./style.css",
  "render": "file:./render.php",
  "supports": {
    "html": false,
    "align": [ "wide" ]
  }
}

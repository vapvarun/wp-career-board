<?xml version="1.0"?>
<ruleset name="WP Career Board">
    <description>WordPress Coding Standards for WP Career Board plugin.</description>

    <!-- Scan only plugin source PHP files -->
    <file>.</file>
    <arg name="extensions" value="php"/>
    <exclude-pattern>*/vendor/*</exclude-pattern>
    <exclude-pattern>*/node_modules/*</exclude-pattern>
    <exclude-pattern>*/dist/*</exclude-pattern>
    <exclude-pattern>*/build/*</exclude-pattern>
    <exclude-pattern>*/tests/*</exclude-pattern>
    <exclude-pattern>*/assets/*</exclude-pattern>
    <exclude-pattern>Gruntfile.js</exclude-pattern>
    <!-- Build-generated asset manifests — not hand-written PHP, no WPCS required. -->
    <exclude-pattern>*/*.asset.php</exclude-pattern>

    <!-- Use WordPress coding standards -->
    <rule ref="WordPress">
        <!--
            Class file names use hyphens between words by WordPress convention
            (e.g. class-admin-meta-boxes.php). The WPCS sniff expects no hyphens
            in class names, which produces false positives. Exclude it plugin-wide.
        -->
        <exclude name="WordPress.Files.FileName.InvalidClassFileName"/>
        <!-- Namespaced compound class names (e.g. Admin_Settings → class-admin-settings.php) -->
        <exclude name="WordPress.Files.FileName.NotHyphenatedLowercase"/>
    </rule>

    <!-- Declare custom WCB capabilities so WPCS does not flag them as unknown -->
    <rule ref="WordPress.WP.Capabilities">
        <properties>
            <property name="custom_capabilities" type="array">
                <element value="wcb_post_jobs"/>
                <element value="wcb_apply_jobs"/>
                <element value="wcb_manage_company"/>
                <element value="wcb_manage_settings"/>
                <element value="wcb_moderate_jobs"/>
                <element value="wcb_view_applications"/>
                <element value="wcb_view_resumes"/>
                <element value="wcb_manage_boards"/>
                <element value="wcb_export_data"/>
                <element value="wcb_delete_any_job"/>
                <element value="wcb_manage_settings"/>
            </property>
        </properties>
    </rule>

    <!-- Minimum PHP version -->
    <config name="testVersion" value="8.1-"/>

    <!-- Text domain -->
    <rule ref="WordPress.WP.I18n">
        <properties>
            <property name="text_domain" type="array">
                <element value="wp-career-board"/>
            </property>
        </properties>
    </rule>
</ruleset>

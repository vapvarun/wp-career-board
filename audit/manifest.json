{
  "$schema": "https://wpmediaverse.com/schemas/wp-plugin-manifest-v1.json",
  "plugin": {
    "slug": "wp-career-board",
    "name": "WP Career Board",
    "version": "1.1.0",
    "namespace": "WCB\\",
    "main_file": "wp-career-board.php",
    "text_domain": "wp-career-board",
    "min_wp": "6.9",
    "min_php": "8.1",
    "extends": null,
    "extension_hook_consumed": null,
    "extension_hook_fired": "wcb_settings_tabs"
  },
  "rest": {
    "namespace": "wcb/v1",
    "endpoints": [
      { "route": "/wcb/v1/jobs",                              "methods": ["GET"],         "handler": "WCB\\Api\\Endpoints\\JobsEndpoint::get_items",                                "permission": "__return_true",                              "purpose": "List jobs with filters/pagination" },
      { "route": "/wcb/v1/jobs",                              "methods": ["POST"],        "handler": "WCB\\Api\\Endpoints\\JobsEndpoint::create_item",                              "permission": "create_item_permissions_check (wcb_post_jobs)",  "purpose": "Create a job posting" },
      { "route": "/wcb/v1/jobs/(?P<id>\\d+)",                 "methods": ["GET"],         "handler": "WCB\\Api\\Endpoints\\JobsEndpoint::get_item",                                  "permission": "__return_true",                              "purpose": "Get a single job" },
      { "route": "/wcb/v1/jobs/(?P<id>\\d+)",                 "methods": ["PUT","PATCH"], "handler": "WCB\\Api\\Endpoints\\JobsEndpoint::update_item",                              "permission": "update_item_permissions_check",                "purpose": "Update an existing job" },
      { "route": "/wcb/v1/jobs/(?P<id>\\d+)",                 "methods": ["DELETE"],      "handler": "WCB\\Api\\Endpoints\\JobsEndpoint::delete_item",                              "permission": "delete_item_permissions_check",                "purpose": "Delete a job" },
      { "route": "/wcb/v1/jobs/(?P<id>\\d+)/bookmark",        "methods": ["POST"],        "handler": "WCB\\Api\\Endpoints\\JobsEndpoint::toggle_bookmark",                          "permission": "is_user_logged_in (inline)",                   "purpose": "Toggle bookmark for the current candidate" },
      { "route": "/wcb/v1/jobs/(?P<id>\\d+)/applications",    "methods": ["GET"],         "handler": "WCB\\Api\\Endpoints\\JobsEndpoint::get_applications",                          "permission": "view_applications_permissions_check",          "purpose": "List applications for a job (employer)" },
      { "route": "/wcb/v1/jobs/(?P<id>\\d+)/apply",           "methods": ["POST"],        "handler": "WCB\\Api\\Endpoints\\ApplicationsEndpoint::submit_application",               "permission": "submit_permissions_check (wcb_apply_jobs)",    "purpose": "Submit an application for a job" },
      { "route": "/wcb/v1/applications/(?P<id>\\d+)",         "methods": ["GET","DELETE"],"handler": "WCB\\Api\\Endpoints\\ApplicationsEndpoint::get_item|withdraw_application",     "permission": "get_item_permissions_check / withdraw_permissions_check", "purpose": "Get or withdraw an application" },
      { "route": "/wcb/v1/applications/(?P<id>\\d+)/status",  "methods": ["PUT","PATCH"], "handler": "WCB\\Api\\Endpoints\\ApplicationsEndpoint::update_status",                    "permission": "update_permissions_check (employer of job)",   "purpose": "Update application status" },
      { "route": "/wcb/v1/candidates/(?P<id>\\d+)/applications","methods": ["GET"],       "handler": "WCB\\Api\\Endpoints\\ApplicationsEndpoint::get_candidate_applications",        "permission": "candidate_permissions_check (self)",           "purpose": "List candidate's own applications" },
      { "route": "/wcb/v1/candidates/resume-upload",          "methods": ["POST"],        "handler": "WCB\\Api\\Endpoints\\ApplicationsEndpoint::upload_resume_file",               "permission": "is_user_logged_in (inline)",                   "purpose": "Upload a resume file (PDF/DOC)" },
      { "route": "/wcb/v1/candidates/(?P<id>\\d+)",           "methods": ["GET","PUT","PATCH"], "handler": "WCB\\Api\\Endpoints\\CandidatesEndpoint::get_item|update_item",          "permission": "get_item_permissions_check / update_item_permissions_check", "purpose": "Get or update a candidate profile" },
      { "route": "/wcb/v1/candidates/(?P<id>\\d+)/bookmarks", "methods": ["GET"],         "handler": "WCB\\Api\\Endpoints\\CandidatesEndpoint::get_bookmarks",                      "permission": "self_permissions_check",                       "purpose": "List candidate bookmarks" },
      { "route": "/wcb/v1/candidates/register",               "methods": ["POST"],        "handler": "WCB\\Api\\Endpoints\\CandidatesEndpoint::register_candidate",                 "permission": "__return_true",                              "purpose": "Public candidate self-registration" },
      { "route": "/wcb/v1/companies",                         "methods": ["GET"],         "handler": "WCB\\Api\\Endpoints\\CompaniesEndpoint::get_items",                            "permission": "__return_true",                              "purpose": "List companies (public directory)" },
      { "route": "/wcb/v1/companies/(?P<id>\\d+)/trust",      "methods": ["POST"],        "handler": "WCB\\Api\\Endpoints\\CompaniesEndpoint::update_trust",                         "permission": "manage_permissions_check (wcb_manage_settings)", "purpose": "Update a company's trust level" },
      { "route": "/wcb/v1/employers/register",                "methods": ["POST"],        "handler": "WCB\\Api\\Endpoints\\EmployersEndpoint::register_employer",                   "permission": "__return_true",                              "purpose": "Public employer self-registration" },
      { "route": "/wcb/v1/employers",                         "methods": ["POST"],        "handler": "WCB\\Api\\Endpoints\\EmployersEndpoint::create_item",                          "permission": "create_item_permissions_check",                "purpose": "Create employer/company (admin)" },
      { "route": "/wcb/v1/employers/(?P<id>\\d+)",            "methods": ["GET","PUT","PATCH"], "handler": "WCB\\Api\\Endpoints\\EmployersEndpoint::get_item|update_item",            "permission": "__return_true / update_item_permissions_check", "purpose": "Get or update an employer profile" },
      { "route": "/wcb/v1/employers/(?P<id>\\d+)/jobs",       "methods": ["GET"],         "handler": "WCB\\Api\\Endpoints\\EmployersEndpoint::get_jobs",                             "permission": "__return_true",                              "purpose": "List jobs posted by an employer" },
      { "route": "/wcb/v1/employers/(?P<id>\\d+)/applications","methods": ["GET"],        "handler": "WCB\\Api\\Endpoints\\EmployersEndpoint::get_applications",                     "permission": "get_applications_permissions_check",           "purpose": "List applications received by an employer" },
      { "route": "/wcb/v1/employers/(?P<id>\\d+)/logo",       "methods": ["POST"],        "handler": "WCB\\Api\\Endpoints\\EmployersEndpoint::upload_logo",                          "permission": "update_item_permissions_check",                "purpose": "Upload employer logo" },
      { "route": "/wcb/v1/employers/me/jobs",                 "methods": ["GET"],         "handler": "WCB\\Api\\Endpoints\\EmployersEndpoint::get_my_jobs",                          "permission": "get_my_jobs_permissions_check",                "purpose": "Current user's posted jobs" },
      { "route": "/wcb/v1/import/status",                     "methods": ["GET"],         "handler": "WCB\\Api\\Endpoints\\ImportEndpoint::get_status",                              "permission": "admin_check (wcb_manage_settings)",            "purpose": "Get import progress" },
      { "route": "/wcb/v1/import/run",                        "methods": ["POST"],        "handler": "WCB\\Api\\Endpoints\\ImportEndpoint::run_batch",                               "permission": "admin_check (wcb_manage_settings)",            "purpose": "Run an import batch" },
      { "route": "/wcb/v1/admin/dismiss-banner",              "methods": ["POST"],        "handler": "WCB\\Api\\Endpoints\\AdminEndpoint::dismiss_banner",                           "permission": "admin_check (wcb_manage_settings)",            "purpose": "Dismiss admin banner / nag" },
      { "route": "/wcb/v1/settings/app-config",               "methods": ["GET"],         "handler": "WCB\\Api\\Endpoints\\SettingsEndpoint::get_app_config",                        "permission": "__return_true",                              "purpose": "Public app config used by frontend blocks" },
      { "route": "/wcb/v1/search",                            "methods": ["GET"],         "handler": "WCB\\Api\\Endpoints\\SearchEndpoint::search",                                  "permission": "__return_true",                              "purpose": "Faceted job search" },
      { "route": "/wcb/v1/wizard/create-pages",               "methods": ["POST"],        "handler": "WCB\\Admin\\SetupWizard::create_pages_handler",                                "permission": "wizard_permission_check (wcb_manage_settings)","purpose": "Setup wizard: auto-create app pages" },
      { "route": "/wcb/v1/wizard/sample-data",                "methods": ["POST"],        "handler": "WCB\\Admin\\SetupWizard::sample_data_handler",                                 "permission": "wizard_permission_check (wcb_manage_settings)","purpose": "Setup wizard: insert sample jobs/companies" },
      { "route": "/wcb/v1/wizard/complete",                   "methods": ["POST"],        "handler": "WCB\\Admin\\SetupWizard::complete_handler",                                    "permission": "wizard_permission_check (wcb_manage_settings)","purpose": "Setup wizard: mark complete" },
      { "route": "/wcb/v1/wizard/remove-sample-data",         "methods": ["POST"],        "handler": "WCB\\Admin\\SetupWizard::remove_sample_data_handler",                          "permission": "wizard_permission_check (wcb_manage_settings)","purpose": "Setup wizard: remove sample data" },
      { "route": "/wcb/v1/jobs/(?P<id>\\d+)/approve",         "methods": ["POST"],        "handler": "WCB\\Modules\\Moderation\\ModerationModule::approve_job",                      "permission": "moderate_permissions_check (wcb_moderate_jobs)","purpose": "Approve a pending job" },
      { "route": "/wcb/v1/jobs/(?P<id>\\d+)/reject",          "methods": ["POST"],        "handler": "WCB\\Modules\\Moderation\\ModerationModule::reject_job",                       "permission": "moderate_permissions_check (wcb_moderate_jobs)","purpose": "Reject a pending job" }
    ]
  },
  "ajax": [],
  "admin_pages": [
    { "title": "Career Board",   "slug": "wp-career-board",                 "parent": null,              "capability": "wcb_manage_settings", "source": "admin/class-admin.php:52" },
    { "title": "Jobs",           "slug": "edit.php?post_type=wcb_job",      "parent": "wp-career-board", "capability": "wcb_manage_settings", "source": "admin/class-admin.php:63" },
    { "title": "Applications",   "slug": "edit.php?post_type=wcb_application","parent": "wp-career-board","capability": "wcb_manage_settings","source": "admin/class-admin.php:74" },
    { "title": "Candidates",     "slug": "edit.php?post_type=wcb_resume",   "parent": "wp-career-board", "capability": "wcb_manage_settings", "source": "admin/class-admin.php:84" },
    { "title": "Companies",      "slug": "edit.php?post_type=wcb_company",  "parent": "wp-career-board", "capability": "wcb_manage_settings", "source": "admin/class-admin.php:93" },
    { "title": "Employers",      "slug": "wcb-employers",                   "parent": "wp-career-board", "capability": "wcb_manage_settings", "source": "admin/class-admin.php:102" },
    { "title": "Settings",       "slug": "wcb-settings",                    "parent": "wp-career-board", "capability": "wcb_manage_settings", "source": "admin/class-admin.php:119" },
    { "title": "Emails",         "slug": "wcb-emails",                      "parent": "wp-career-board", "capability": "wcb_manage_settings", "source": "admin/class-admin.php:499" },
    { "title": "Setup Wizard",   "slug": "wcb-setup-wizard",                "parent": "wp-career-board", "capability": "wcb_manage_settings", "source": "admin/class-setup-wizard.php" }
  ],
  "settings": [
    { "key": "wcb_settings",         "group": "wcb_settings_group", "type": "array",  "default": "[]", "controls": "Main plugin settings (listings/pages/notifications tabs) — registered via Settings API in admin/class-admin-settings.php" },
    { "key": "wcb_email_settings",   "group": "n/a (admin-post)",   "type": "array",  "default": "[]", "controls": "Per-email enable/from/subject — admin/class-email-settings.php" },
    { "key": "wcb_page_settings",    "group": "filter-only",        "type": "array",  "default": "[]", "controls": "WCB app-page IDs (where blocks live); read via wcb_app_page_ids filter" },
    { "key": "wcb_setup_complete",   "group": "n/a",                "type": "bool",   "default": "false","controls": "Setup wizard completion flag" },
    { "key": "wcb_db_version",       "group": "n/a",                "type": "string", "default": "0",  "controls": "DB schema version, used by Install::maybe_upgrade()" },
    { "key": "wcb_default_board_id", "group": "n/a",                "type": "int",    "default": "0",  "controls": "Default wcb_board ID used when no board attribute is supplied" },
    { "key": "wcb_captcha_driver",   "group": "n/a (admin-post)",   "type": "string", "default": "none","controls": "AntiSpam: none|recaptcha|turnstile (modules/antispam)" },
    { "key": "wcb_jobs_cache_v",     "group": "n/a",                "type": "int",    "default": "0",  "controls": "Cache busting key for jobs index" },
    { "key": "wcb_sample_data_ids",  "group": "n/a",                "type": "array",  "default": "[]", "controls": "IDs of sample data inserted by setup wizard" },
    { "key": "wcb_sample_data_installed","group": "n/a",            "type": "bool",   "default": "false","controls": "Whether sample data is currently installed" }
  ],
  "shortcodes": [
    { "tag": "wcb_widget",              "handler": "WCB\\Core\\Widgets\\WidgetRegistry::render", "attrs": ["id","args"] },
    { "tag": "wcb_job_listings",        "handler": "core/class-plugin.php (block adapter → wp-career-board/job-listings)",        "attrs": ["boardId","metaFilter","perPage","layout"] },
    { "tag": "wcb_job_search",          "handler": "core/class-plugin.php (block adapter → wp-career-board/job-search)",          "attrs": [] },
    { "tag": "wcb_job_form",            "handler": "core/class-plugin.php (block adapter → wp-career-board/job-form)",            "attrs": [] },
    { "tag": "wcb_job_form_simple",     "handler": "core/class-plugin.php (block adapter → wp-career-board/job-form-simple)",     "attrs": [] },
    { "tag": "wcb_employer_dashboard",  "handler": "core/class-plugin.php (block adapter → wp-career-board/employer-dashboard)",  "attrs": [] },
    { "tag": "wcb_candidate_dashboard", "handler": "core/class-plugin.php (block adapter → wp-career-board/candidate-dashboard)", "attrs": [] },
    { "tag": "wcb_registration",        "handler": "core/class-plugin.php (block adapter → wp-career-board/employer-registration)","attrs": [] },
    { "tag": "wcb_company_archive",     "handler": "core/class-plugin.php (block adapter → wp-career-board/company-archive)",     "attrs": [] },
    { "tag": "wcb_job_stats",           "handler": "core/class-plugin.php (block adapter → wp-career-board/job-stats)",           "attrs": [] },
    { "tag": "wcb_recent_jobs",         "handler": "core/class-plugin.php (block adapter → wp-career-board/recent-jobs)",         "attrs": [] }
  ],
  "blocks": [
    { "name": "wp-career-board/job-listings",          "render": "blocks/job-listings/render.php",          "interactivity": true,  "view_module": "blocks/job-listings/view.js" },
    { "name": "wp-career-board/job-form",              "render": "blocks/job-form/render.php",              "interactivity": true,  "view_module": "blocks/job-form/view.js" },
    { "name": "wp-career-board/job-form-simple",       "render": "blocks/job-form-simple/render.php",       "interactivity": true,  "view_module": "blocks/job-form-simple/view.js" },
    { "name": "wp-career-board/job-single",            "render": "blocks/job-single/render.php",            "interactivity": true,  "view_module": "blocks/job-single/view.js" },
    { "name": "wp-career-board/job-search",            "render": "blocks/job-search/render.php",            "interactivity": true,  "view_module": "blocks/job-search/view.js" },
    { "name": "wp-career-board/job-search-hero",       "render": "blocks/job-search-hero/render.php",       "interactivity": false, "view_module": null },
    { "name": "wp-career-board/job-filters",           "render": "blocks/job-filters/render.php",           "interactivity": true,  "view_module": "blocks/job-filters/view.js" },
    { "name": "wp-career-board/job-stats",             "render": "blocks/job-stats/render.php",             "interactivity": false, "view_module": null },
    { "name": "wp-career-board/featured-jobs",         "render": "blocks/featured-jobs/render.php",         "interactivity": false, "view_module": null },
    { "name": "wp-career-board/recent-jobs",           "render": "blocks/recent-jobs/render.php",           "interactivity": false, "view_module": null },
    { "name": "wp-career-board/candidate-dashboard",   "render": "blocks/candidate-dashboard/render.php",   "interactivity": true,  "view_module": "blocks/candidate-dashboard/view.js" },
    { "name": "wp-career-board/employer-dashboard",    "render": "blocks/employer-dashboard/render.php",    "interactivity": true,  "view_module": "blocks/employer-dashboard/view.js" },
    { "name": "wp-career-board/employer-registration", "render": "blocks/employer-registration/render.php", "interactivity": true,  "view_module": "blocks/employer-registration/view.js" },
    { "name": "wp-career-board/company-profile",       "render": "blocks/company-profile/render.php",       "interactivity": true,  "view_module": "blocks/company-profile/view.js" },
    { "name": "wp-career-board/company-archive",       "render": "blocks/company-archive/render.php",       "interactivity": true,  "view_module": "blocks/company-archive/view.js" }
  ],
  "post_types": [
    { "slug": "wcb_job",         "where": "modules/jobs/class-jobs-module.php:155",         "public": true,  "purpose": "Job postings" },
    { "slug": "wcb_application", "where": "modules/applications/class-applications-module.php:60", "public": false, "purpose": "Job applications" },
    { "slug": "wcb_company",     "where": "modules/employers/class-employers-module.php:133",     "public": true,  "purpose": "Employer/company profile" },
    { "slug": "wcb_resume",      "where": "modules/candidates/class-candidates-module.php:40",    "public": false, "purpose": "Candidate resume/profile" },
    { "slug": "wcb_board",       "where": "modules/boards/class-boards-module.php:41",            "public": false, "purpose": "Job board (multi-board grouping)" }
  ],
  "taxonomies": [
    { "slug": "wcb_category",   "object_type": "wcb_job", "where": "modules/jobs/class-jobs-module.php:192", "purpose": "Job category" },
    { "slug": "wcb_job_type",   "object_type": "wcb_job", "where": "modules/jobs/class-jobs-module.php:205", "purpose": "Employment type (full-time, part-time, …)" },
    { "slug": "wcb_tag",        "object_type": "wcb_job", "where": "modules/jobs/class-jobs-module.php:218", "purpose": "Free-form tags" },
    { "slug": "wcb_location",   "object_type": "wcb_job", "where": "modules/jobs/class-jobs-module.php:229", "purpose": "Job location" },
    { "slug": "wcb_experience", "object_type": "wcb_job", "where": "modules/jobs/class-jobs-module.php:242", "purpose": "Experience level" }
  ],
  "tables": [
    { "name": "{prefix}wcb_notifications_log", "purpose": "Audit log of emails/notifications sent", "where": "core/class-install.php" },
    { "name": "{prefix}wcb_job_views",         "purpose": "Per-job view counter (de-duped via ip_hash)", "where": "core/class-install.php" },
    { "name": "{prefix}wcb_gdpr_log",          "purpose": "GDPR action audit trail (export/erase)", "where": "core/class-install.php" }
  ],
  "capabilities": [
    { "cap": "wcb_post_jobs",                  "default_roles": ["wcb_employer", "administrator"], "ability_id": "wcb_post_jobs",                  "where": "core/class-abilities.php:71" },
    { "cap": "wcb_manage_company",             "default_roles": ["wcb_employer", "administrator"], "ability_id": "wcb_manage_company",             "where": "core/class-abilities.php:87" },
    { "cap": "wcb_view_applications",          "default_roles": ["wcb_employer", "administrator"], "ability_id": "wcb_view_applications",          "where": "core/class-abilities.php:103" },
    { "cap": "wcb_access_employer_dashboard",  "default_roles": ["wcb_employer", "administrator"], "ability_id": "wcb_access_employer_dashboard",  "where": "core/class-abilities.php:119" },
    { "cap": "wcb_apply_jobs",                 "default_roles": ["wcb_candidate", "administrator"],"ability_id": "wcb_apply_jobs",                 "where": "core/class-abilities.php:143" },
    { "cap": "wcb_manage_resume",              "default_roles": ["wcb_candidate", "administrator"],"ability_id": "wcb_manage_resume",              "where": "core/class-abilities.php:159" },
    { "cap": "wcb_bookmark_jobs",              "default_roles": ["wcb_candidate", "administrator"],"ability_id": "wcb_bookmark_jobs",              "where": "core/class-abilities.php:175" },
    { "cap": "wcb_access_candidate_dashboard", "default_roles": ["wcb_candidate", "administrator"],"ability_id": "wcb_access_candidate_dashboard", "where": "core/class-abilities.php:191" },
    { "cap": "wcb_moderate_jobs",              "default_roles": ["wcb_board_moderator", "administrator"], "ability_id": "wcb_moderate_jobs",       "where": "core/class-abilities.php:217" },
    { "cap": "wcb_manage_settings",            "default_roles": ["administrator"],                  "ability_id": "wcb_manage_settings",            "where": "core/class-abilities.php:244" },
    { "cap": "wcb_view_analytics",             "default_roles": ["administrator"],                  "ability_id": "wcb_view_analytics",             "where": "core/class-abilities.php:261" }
  ],
  "services": [
    { "key": "core.plugin",         "class": "WCB\\Core\\Plugin",                 "added": "1.0.0", "purpose": "Singleton bootloader" },
    { "key": "core.roles",          "class": "WCB\\Core\\Roles",                  "added": "1.0.0", "purpose": "Custom role registration + cap sync" },
    { "key": "core.abilities",      "class": "WCB\\Core\\Abilities",              "added": "1.0.0", "purpose": "Abilities API registration" },
    { "key": "core.industries",     "class": "WCB\\Core\\Industries",             "added": "1.0.0", "purpose": "Industry taxonomy seed data" },
    { "key": "core.install",        "class": "WCB\\Core\\Install",                "added": "1.0.0", "purpose": "Activation, dbDelta tables, upgrades" },
    { "key": "core.theme_bridge",   "class": "WCB\\Core\\ThemeAccentBridge",      "added": "1.0.0", "purpose": "Map theme accent → wcb-* CSS vars" },
    { "key": "core.widgets",        "class": "WCB\\Core\\Widgets\\WidgetRegistry","added": "1.0.0", "purpose": "Widget + [wcb_widget] shortcode adapter" },
    { "key": "admin.admin",         "class": "WCB\\Admin\\Admin",                 "added": "1.0.0", "purpose": "Admin menu + assets" },
    { "key": "admin.settings",      "class": "WCB\\Admin\\AdminSettings",         "added": "1.0.0", "purpose": "Main settings page (Listings / Pages / Notifications tabs)" },
    { "key": "admin.email_settings","class": "WCB\\Admin\\EmailSettings",         "added": "1.0.0", "purpose": "Email-per-event settings page" },
    { "key": "admin.setup_wizard",  "class": "WCB\\Admin\\SetupWizard",           "added": "1.0.0", "purpose": "First-run wizard (pages, sample data)" },
    { "key": "admin.applications",  "class": "WCB\\Admin\\AdminApplications",     "added": "1.0.0", "purpose": "Applications admin list-table screens" },
    { "key": "admin.candidates",    "class": "WCB\\Admin\\AdminCandidates",       "added": "1.0.0", "purpose": "Candidates admin list-table screens" },
    { "key": "admin.companies",     "class": "WCB\\Admin\\AdminCompanies",        "added": "1.0.0", "purpose": "Companies admin list-table screens" },
    { "key": "admin.employers",     "class": "WCB\\Admin\\AdminEmployers",        "added": "1.0.0", "purpose": "Employers admin screen" },
    { "key": "admin.import",        "class": "WCB\\Admin\\AdminImport",           "added": "1.0.0", "purpose": "Import (WPJM) admin tab" },
    { "key": "admin.jobs",          "class": "WCB\\Admin\\AdminJobs",             "added": "1.0.0", "purpose": "Jobs admin list-table screens" },
    { "key": "admin.meta_boxes",    "class": "WCB\\Admin\\AdminMetaBoxes",        "added": "1.0.0", "purpose": "Meta-box rendering for wcb_* CPTs" },
    { "key": "module.jobs",         "class": "WCB\\Modules\\Jobs\\JobsModule",          "added": "1.0.0", "purpose": "wcb_job CPT + taxonomies + meta + cron sub-services" },

{
    "name": "wbcom/wp-career-board",
    "description": "WP Career Board",
    "type": "wordpress-plugin",
    "license": "proprietary",
    "require-dev": {
        "phpstan/phpstan": "^2.1",
        "szepeviktor/phpstan-wordpress": "^2.0",

        "wp-coding-standards/wpcs": "dev-develop",
        "dealerdirect/phpcodesniffer-composer-installer": "*",
        "php-stubs/wp-cli-stubs": "^2.12"
    },
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    },
    "scripts": {
        "install-hooks": "git config core.hooksPath .githooks && echo 'hooks installed: pre-commit + pre-push (.githooks/ + bin/git-hooks/)'",
        "phpcs": "vendor/bin/phpcs --standard=phpcs.xml",
        "phpcbf": "vendor/bin/phpcbf --standard=phpcs.xml",
        "phpstan": "vendor/bin/phpstan analyse --memory-limit=2G",
        "lint": [
            "@phpcs",
            "@phpstan"
        ],
        "coding-rules": "bin/coding-rules-check.sh --full",
        "qa-coverage": "php bin/qa-coverage-check.php",
        "qa-coverage:strict": "php bin/qa-coverage-check.php --strict",
        "ci:quick": [
            "@phpstan",
            "@coding-rules"
        ],
        "ci:no-journeys": [
            "@phpstan",
            "@phpcs",
            "@coding-rules",
            "@qa-coverage"
        ],
        "journeys": "bin/run-journeys.sh --priority=critical",
        "journeys:dry-run": "bin/run-journeys.sh --dry-run",
        "journeys:list": "bin/run-journeys.sh --list",
        "journeys:stale": "bin/run-journeys.sh --audit-stale",
        "ci": [
            "@ci:no-journeys",
            "@journeys"
        ],
        "scale:seed": "wp --path=../../.. --user=1 wcb scale seed",
        "scale:bench": "wp --path=../../.. --user=1 wcb scale benchmark",
        "scale:teardown": "wp --path=../../.. --user=1 wcb scale teardown"
    }
}

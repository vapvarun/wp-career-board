# Worktrees
.worktrees/

# Dependencies — track production SDKs, ignore dev packages
/vendor/*
!/vendor/edd-sl-sdk/
node_modules/

# Build output
build/
assets/js/build/
assets/css/build/

# dist/ holds only release zips — never the source mirror that grunt dist generates.
dist/*
!dist/*.zip

# Environment
.env
.env.*

# IDE
.idea/
.vscode/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Logs
*.log

.codex

# Worktrees
.worktrees/

# Dependencies — dev packages only; bundled runtime SDKs live in /libs (tracked).
/vendor/*
node_modules/

# Build output
build/
assets/js/build/
assets/css/build/

# Bundled SDK build assets MUST ship (the generic build/ above would hide them).
# Same incident as Jetonomy 1.4.2: a release shipped without edd-sl-sdk.js.
!libs/edd-sl-sdk/assets/build/
!libs/edd-sl-sdk/assets/build/**

# dist/ holds only release zips — never the source mirror that grunt dist generates.
dist/*
!dist/*.zip

# Environment
.env
.env.*

# IDE
.idea/
.vscode/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Logs
*.log

.codex

# QA run-report scratch — committed manifest + journeys + qa-coverage stay tracked,
# but per-run reports are output and shouldn't pollute the diff.
audit/journey-runs/
docs/qa/.last-smoke-pass*.json
docs/qa/.debug-log-*.txt

{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "text": {
    "$description": "Type scale - font-size in rem. Maps to --wcb-text-* CSS custom properties.",
    "xs":   { "$type": "dimension", "$value": "0.75rem" },
    "sm":   { "$type": "dimension", "$value": "0.8125rem" },
    "base": { "$type": "dimension", "$value": "0.875rem" },
    "md":   { "$type": "dimension", "$value": "0.9375rem" },
    "lg":   { "$type": "dimension", "$value": "1.125rem" },
    "xl":   { "$type": "dimension", "$value": "1.25rem" },
    "2xl":  { "$type": "dimension", "$value": "1.5rem" },
    "3xl":  { "$type": "dimension", "$value": "2rem" }
  },
  "font": {
    "$type": "fontWeight",
    "$description": "Font weights - maps to --wcb-font-* CSS custom properties.",
    "normal":   { "$value": 400 },
    "medium":   { "$value": 500 },
    "semibold": { "$value": 600 },
    "bold":     { "$value": 700 }
  },
  "leading": {
    "$type": "number",
    "$description": "Unitless line-height multipliers. Maps to --wcb-leading-* CSS custom properties.",
    "tight":   { "$value": 1.25 },
    "normal":  { "$value": 1.5 },
    "relaxed": { "$value": 1.625 }
  }
}

{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "color": {
    "$type": "color",
    "$description": "Semantic colors - status palette, neutrals, primary tints. Core palette (primary/base/contrast) lives in frontend.css and is theme-overridable; tokens here are the supplementary semantic layer.",

    "text": {
      "secondary": { "$value": "#6b7280" },
      "tertiary":  { "$value": "#9ca3af" }
    },

    "bg": {
      "subtle": { "$value": "#f8fafc" },
      "hover":  { "$value": "#f1f5f9" }
    },

    "success": {
      "$description": "Positive status - applied, approved, verified, complete.",
      "base":    { "$value": "#16a34a" },
      "fg":      { "$value": "#166534" },
      "bg":      { "$value": "#dcfce7" },
      "bg-soft": { "$value": "#f0fdf4" },
      "border":  { "$value": "#bbf7d0" }
    },

    "warning": {
      "$description": "Caution status - pending, rate-limit, near-expiry.",
      "base":    { "$value": "#d97706" },
      "fg":      { "$value": "#92400e" },
      "bg":      { "$value": "#fef3c7" },
      "bg-soft": { "$value": "#fffbeb" },
      "border":  { "$value": "#fde68a" }
    },

    "danger": {
      "$description": "Error status - rejected, failed, destructive actions.",
      "base":    { "$value": "#dc2626" },
      "fg":      { "$value": "#991b1b" },
      "bg":      { "$value": "#fee2e2" },
      "bg-soft": { "$value": "#fef2f2" },
      "border":  { "$value": "#fecaca" }
    },

    "info": {
      "$description": "Informational status - new, neutral notice, link.",
      "base":    { "$value": "#2563eb" },
      "fg":      { "$value": "#1d4ed8" },
      "bg":      { "$value": "#dbeafe" },
      "bg-soft": { "$value": "#eff6ff" },
      "border":  { "$value": "#bfdbfe" }
    },

    "teal": {
      "$description": "Trust accent - verified company badges, open-to-work, resume completeness meters.",
      "base":    { "$value": "#0d9488" },
      "fg":      { "$value": "#0f766e" },
      "bg":      { "$value": "#ccfbf1" },
      "bg-soft": { "$value": "#f0fdfa" }
    }
  }
}

{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "icon": {
    "$description": "Lucide icon sizes + stroke width. Maps to --wcb-icon-* CSS custom properties.",
    "xs":     { "$type": "dimension", "$value": "14px" },
    "sm":     { "$type": "dimension", "$value": "16px" },
    "md":     { "$type": "dimension", "$value": "18px" },
    "lg":     { "$type": "dimension", "$value": "24px" },
    "xl":     { "$type": "dimension", "$value": "32px" },
    "2xl":    { "$type": "dimension", "$value": "48px" },
    "stroke": { "$type": "number",    "$value": 1.75 }
  }
}

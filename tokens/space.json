{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "space": {
    "$type": "dimension",
    "$description": "Spacing scale - used for padding, margin, gap. Maps 1:1 to --wcb-space-* CSS custom properties.",
    "xs":  { "$value": "4px" },
    "sm":  { "$value": "8px" },
    "md":  { "$value": "12px" },
    "lg":  { "$value": "16px" },
    "xl":  { "$value": "20px" },
    "2xl": { "$value": "24px" },
    "3xl": { "$value": "32px" },
    "4xl": { "$value": "48px" }
  }
}

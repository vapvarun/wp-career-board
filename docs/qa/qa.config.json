  "fixture_cleanup_sql": [
    "DELETE FROM {prefix}posts WHERE post_type IN ('wcb_job','wcb_application','wcb_resume','wcb_company','wcb_board','wcb_credit_package') AND (post_title LIKE 'Smoke %' OR post_title LIKE 'Smoke-Batch%' OR post_title LIKE 'E2E %')",
    "DELETE FROM {prefix}postmeta WHERE meta_key = '_wcb_qa_smoke'",
    "DELETE FROM {prefix}usermeta WHERE meta_key = '_wcb_qa_smoke'"
  ],

  "debug_log_whitelist": [
    "PHP Warning.*paid-memberships-pro.*Undefined array key 'hook'",
    "PHP Warning.*edd-sl-sdk.*Undefined property stdClass::\\$expires",
    "PHP Notice.*BuddyPress.*"
  ],

  "outputs": {
    "smoke_report":      "docs/qa/.last-smoke-pass.json",
    "journey_runs_dir":  "audit/journey-runs",
    "screenshots_dir":   "audit/journey-runs/{run_id}/screenshots",
    "debug_log_archive": "docs/qa/.debug-log-{version}-{ran_at}.txt"
  }
}
